rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function ownsUserDocument(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == "admin";
    }

    function isTeacherAssignedTo(studentId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/teacherStudentLinks/$(request.auth.uid + "_" + studentId))
        && get(/databases/$(database)/documents/teacherStudentLinks/$(request.auth.uid + "_" + studentId)).data.status == "active";
    }

    function isClassroomMember(classroomId) {
      return isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherIds;
    }

    function onlyChanged(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    match /users/{userId} {
      allow read: if ownsUserDocument(userId);
      allow create: if ownsUserDocument(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role in ["student", "teacher"];
      allow update: if ownsUserDocument(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role;
      allow delete: if false;

      match /learning/{documentId} {
        allow read, create, update: if ownsUserDocument(userId)
          && documentId == "progress";
        allow delete: if false;
      }

      match /learningEvents/{eventId} {
        allow create: if ownsUserDocument(userId)
          && request.resource.data.keys().hasOnly(["userId", "type", "label", "area", "metadata", "createdAt", "environment", "firebaseProjectId"])
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.type in [
            "reading_started",
            "word_known",
            "word_listened",
            "word_skipped",
            "reading_completed",
            "sound_listened",
            "sentence_listened",
            "memory_started",
            "memory_card_revealed",
            "memory_match",
            "memory_attempt",
            "memory_completed",
            "activity_started",
            "activity_prompt_listened",
            "activity_answer",
            "activity_round_advanced",
            "activity_completed"
          ]
          && request.resource.data.label is string
          && request.resource.data.label.size() >= 1
          && request.resource.data.label.size() <= 180
          && request.resource.data.area in ["phonics", "sightWords", "fluency", "workingMemory", "consistency"]
          && request.resource.data.metadata is map
          && request.resource.data.metadata.size() <= 16
          && request.resource.data.createdAt != null;
        allow read: if ownsUserDocument(userId) || isTeacherAssignedTo(userId);
        allow update, delete: if false;
      }

      match /learningSummaries/{summaryId} {
        allow read: if ownsUserDocument(userId) || isTeacherAssignedTo(userId);
        allow create, update, delete: if false;
      }

      match /aiInsights/{insightId} {
        allow read: if ownsUserDocument(userId) || isTeacherAssignedTo(userId);
        allow create, update, delete: if false;
      }

      match /learningCoachState/{stateId} {
        allow read: if ownsUserDocument(userId) || isTeacherAssignedTo(userId);
        allow create, update, delete: if false;
      }
    }

    match /subscriptions/{userId} {
      allow read: if ownsUserDocument(userId) || isAdmin();
      allow create, update, delete: if false;
    }

    match /testSubscriptions/{userId} {
      allow read: if ownsUserDocument(userId) || isAdmin();
      allow create, update, delete: if false;
    }

    match /childProfiles/{childId} {
      allow read: if isSignedIn()
        && resource.data.parentUid == request.auth.uid;
      allow create, update: if isSignedIn()
        && request.resource.data.parentUid == request.auth.uid;
      allow delete: if false;
    }

    match /teacherProfiles/{teacherId} {
      allow read: if ownsUserDocument(teacherId);
      allow create: if ownsUserDocument(teacherId)
        && request.resource.data.uid == request.auth.uid
        && userRole() == "teacher";
      allow update: if ownsUserDocument(teacherId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.activeStudentCount == resource.data.activeStudentCount
        && request.resource.data.certificationStatus == resource.data.certificationStatus;
      allow delete: if false;
    }

    match /teacherDirectory/{teacherId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn()
        && request.query.limit <= 12;
      allow create: if ownsUserDocument(teacherId)
        && request.resource.data.uid == request.auth.uid
        && userRole() == "teacher";
      allow update: if ownsUserDocument(teacherId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.activeStudentCount == resource.data.activeStudentCount
        && request.resource.data.certificationStatus == resource.data.certificationStatus;
      allow delete: if false;
    }

    match /teacherStudentLinks/{linkId} {
      allow create: if isSignedIn()
        && linkId == request.resource.data.teacherId + "_" + request.auth.uid
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.status == "requested"
        && exists(/databases/$(database)/documents/teacherProfiles/$(request.resource.data.teacherId));
      allow read: if isSignedIn()
        && (resource.data.studentId == request.auth.uid || resource.data.teacherId == request.auth.uid);
      allow update: if isSignedIn()
        && resource.data.studentId == request.auth.uid
        && resource.data.status in ["requested", "active"]
        && request.resource.data.studentId == resource.data.studentId
        && request.resource.data.teacherId == resource.data.teacherId
        && onlyChanged(["latestProgressSnapshot", "updatedAt"]);
      allow delete: if false;
    }

    match /studentPlacementQueue/{studentId} {
      allow get: if ownsUserDocument(studentId) || userRole() == "teacher" || isAdmin();
      allow list: if isSignedIn()
        && (userRole() == "teacher" || isAdmin())
        && request.query.limit <= 25;
      allow create: if ownsUserDocument(studentId)
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.status in ["unassigned", "requested"]
        && request.resource.data.studentName is string
        && request.resource.data.latestProgressSnapshot != null;
      allow update: if ownsUserDocument(studentId)
        && resource.data.status != "assigned"
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.status in ["unassigned", "requested"]
        && request.resource.data.studentName is string
        && request.resource.data.latestProgressSnapshot != null;
      allow delete: if false;
    }

    match /teacherInvites/{inviteId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn()
        && request.query.limit <= 20;
      allow create: if isSignedIn()
        && userRole() == "teacher"
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.status == "active"
        && request.resource.data.code is string
        && request.resource.data.autoApprove is bool;
      allow update: if isSignedIn()
        && (
          (
            resource.data.teacherId == request.auth.uid
            && request.resource.data.teacherId == resource.data.teacherId
            && request.resource.data.status in ["active", "revoked", "expired"]
          )
          || (
            userRole() == "student"
            && resource.data.status == "active"
            && request.resource.data.teacherId == resource.data.teacherId
            && request.resource.data.status == "accepted"
            && request.resource.data.acceptedBy == request.auth.uid
            && onlyChanged(["status", "acceptedBy", "acceptedAt", "updatedAt", "updatedBy"])
          )
        );
      allow delete: if false;
    }

    match /analyticsEvents/{eventId} {
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(["eventName", "metadata", "userId", "createdAt"])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.eventName in [
          "signup_started",
          "signup_completed",
          "onboarding_completed",
          "activity_started",
          "activity_completed",
          "practice_streak",
          "paywall_viewed",
          "checkout_clicked",
          "subscription_active",
          "subscription_canceled",
          "teacher_invite_sent",
          "teacher_invite_accepted",
          "report_downloaded",
          "ai_insight_requested"
        ]
        && request.resource.data.metadata is map
        && request.resource.data.metadata.size() <= 12
        && request.resource.data.createdAt != null;
      allow read, update, delete: if false;
    }

    match /supportCases/{caseId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow create, delete: if false;
    }

    match /abuseRateLimits/{limitId} {
      allow read, create, update, delete: if false;
    }

    match /systemLogs/{logId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /aiRecommendationRequests/{requestId} {
      allow read: if isSignedIn()
        && (resource.data.requestedBy == request.auth.uid || isAdmin());
      allow create, update, delete: if false;
    }

    match /aiAnalysisJobs/{jobId} {
      allow read: if isSignedIn()
        && (
          resource.data.requestedBy == request.auth.uid
          || resource.data.studentId == request.auth.uid
          || isTeacherAssignedTo(resource.data.studentId)
          || isAdmin()
        );
      allow create, update, delete: if false;
    }

    match /aiBudget/{document=**} {
      allow read, create, update, delete: if false;
    }

    match /classrooms/{classroomId} {
      allow read: if isSignedIn()
        && (userRole() == "admin" || isClassroomMember(classroomId));
      allow create: if isSignedIn()
        && userRole() == "teacher"
        && request.resource.data.teacherIds.hasOnly([request.auth.uid]);
      allow update: if isSignedIn()
        && (
          userRole() == "admin"
          || (
            isClassroomMember(classroomId)
            && request.resource.data.teacherIds == resource.data.teacherIds
          )
        );
      allow delete: if false;

      match /students/{studentId} {
        allow read, create, update: if isSignedIn()
          && (userRole() == "admin" || isClassroomMember(classroomId));
        allow delete: if false;
      }

      match /analyses/{analysisId} {
        allow read, create, update: if isSignedIn()
          && (userRole() == "admin" || isClassroomMember(classroomId));
        allow delete: if false;
      }
    }
  }
}
