VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=
VITE_AUTH0_REDIRECT_URI=http://localhost:4173
VITE_AUTH0_GOOGLE_CONNECTION=google-oauth2
VITE_AUTH0_FACEBOOK_CONNECTION=facebook
VITE_AUTH0_INSTAGRAM_CONNECTION=instagram

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
# Public reCAPTCHA v3 site key used by Firebase App Check.
VITE_FIREBASE_APP_CHECK_SITE_KEY=

VITE_STRIPE_DONATION_LINK=
VITE_STRIPE_FAMILY_PLUS_LINK=
VITE_STRIPE_TEACHER_PRO_LINK=
VITE_STRIPE_CUSTOMER_PORTAL_LINK=

VITE_SUPPORT_EMAIL=support@myreadnest.org

VITE_BASE_PATH=/

# Firebase Functions / backend runtime values. Do not expose these as Vite variables.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_FAMILY_PLUS_PRICE_ID=
STRIPE_TEACHER_PRO_PRICE_ID=
READNEST_APP_BASE_URL=https://myreadnest.org/
# Set true only after App Check metrics show valid requests from the deployed app.
READNEST_ENFORCE_APP_CHECK=false

# Optional future AI provider secret. Store as a Firebase Functions secret, never as VITE_*.
OPENAI_API_KEY=
READNEST_AI_MODEL=
READNEST_AI_WARNING_LIMIT_USD=10
READNEST_AI_MONTHLY_LIMIT_USD=15
READNEST_AI_ESTIMATED_COST_PER_INSIGHT_USD=0.05
READNEST_AI_INPUT_COST_PER_1M_USD=
READNEST_AI_OUTPUT_COST_PER_1M_USD=

# Optional support email automation. Store RESEND_API_KEY as a Firebase Functions secret.
RESEND_API_KEY=
SUPPORT_NOTIFICATION_EMAIL=support@myreadnest.org
SUPPORT_FROM_EMAIL=ReadNest Support <support@myreadnest.org>
